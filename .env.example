# Ambiente: development | production
NODE_ENV=development

# Servidor HTTP
PORT=3000

# CORS: origem permitida (ex.: http://localhost:5173) ou * para qualquer origem
CORS_ORIGIN=*

# Chave secreta para JWT (defina um valor forte em produção)
JWT_SECRET=

# Google Maps — usada pela rota /api/config/google-maps-key
GOOGLE_MAPS_API_KEY=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nimu_pwa_db
DB_USER=postgres
DB_PASSWORD=
# true para conexões que exigem SSL (ex.: provedores em nuvem)
DB_SSL=false
# Schema das tabelas FitPoint
DB_SCHEMA=fitpoint

# Credenciais do admin inicial (script scripts/migrate.js)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=0aYC5V6R083WxfPerMhVhlHm
